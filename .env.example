# Neon Serverless Postgres (Postgres connection string)
# For a pooled connection, use the pooled connection string from the Neon Console.
DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require

# Express API port
PORT=3001

# Frontend (Vite) API base.
# - Leave blank to use same-origin in dev/proxy, or GitHub Pages base path in production.
# - Set this to your deployed Express API URL if it's hosted elsewhere (e.g. Render/Fly/Vercel).
VITE_API_BASE=

