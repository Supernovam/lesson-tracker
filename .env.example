# Neon Serverless Postgres (Postgres connection string)
# For a pooled connection, use the pooled connection string from the Neon Console.
DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require

# Express API port
PORT=3001

# CORS allow-list for browser requests (scheme+host only, comma-separated).
# In production, set this to include your GitHub Pages origin and your Render API origin.
# Example:
# CORS_ORIGINS=https://supernovam.github.io,https://lesson-tracker-api-xxxxx.onrender.com
CORS_ORIGINS=

# (Optional) Override the Vite dev proxy target for `/api` when running locally.
VITE_DEV_API_URL=http://localhost:3001

# Frontend (Vite) API base.
# - Leave blank in dev so Vite's proxy forwards `/api/*` to the local Express server.
# - In GitHub Pages production builds, set this to your deployed Express API origin (e.g. Render).
VITE_API_BASE=

